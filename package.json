{
  "name": "ffc-ahwr-common-library",
  "version": "3.8.2",
  "description": "Common functionality npm module for ahwr services",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DEFRA/ffc-ahwr-common-library.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "github:release": "npx cdp-github-release ffc-ahwr-common-library",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prettier": "prettier --check \"**/*.{cjs,js,json}\"",
    "prettier:fix": "prettier --write \"**/*.{cjs,js,json}\"",
    "publish:changed": "changeset publish",
    "test": "jest",
    "version:changed": "changeset version",
    "version:create": "changeset"
  },
  "author": "Defra AHWR Team",
  "exports": "./index.js",
  "license": "OGL-UK-3.0",
  "bugs": {
    "url": "https://github.com/DEFRA/ffc-ahwr-common-library/issues"
  },
  "homepage": "https://github.com/DEFRA/ffc-ahwr-common-library#readme",
  "dependencies": {
    "@aws-sdk/client-sns": "3.1015.0",
    "@aws-sdk/client-sqs": "3.1015.0",
    "@azure/service-bus": "7.9.5",
    "joi": "18.2.1",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/plugin-transform-export-namespace-from": "7.29.7",
    "@babel/plugin-transform-modules-commonjs": "7.29.7",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "babel-jest": "30.4.1",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-junit": "17.0.0",
    "nano-staged": "1.0.2",
    "neostandard": "0.13.0"
  },
  "babel": {
    "plugins": [
      "@babel/plugin-transform-modules-commonjs"
    ]
  },
  "release-it": {
    "npm": {
      "publish": false
    },
    "github": {
      "release": true,
      "releaseName": "Release ${version}",
      "releaseNotes": "echo ''"
    },
    "git": {
      "commitMessage": "Tagged ffc-ahwr-common-library ${version}",
      "tagName": "ffc-ahwr-common-library-${version}",
      "requireCleanWorkingDir": false,
      "commitArgs": [
        "--no-verify"
      ]
    }
  },
  "bin": {
    "cdp-github-release": "ci/release-it.sh"
  },
  "nano-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
